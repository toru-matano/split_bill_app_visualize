# =============================================================================
# .env.example — copy to .env.local for local development
# All variables marked [REQUIRED] must be set in Vercel (or your host) too.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Supabase [REQUIRED]
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key — NEVER expose client-side>

# ─────────────────────────────────────────────────────────────────────────────
# AES-256-GCM encryption keys (improvement #4 — key versioning)
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# PII_ENCRYPTION_KEY    — current active key (version byte 0x01)
# PII_ENCRYPTION_KEY_V2 — next key for rotation (version byte 0x02)
#                          Leave unset until you begin a key rotation.
# ─────────────────────────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=<64-char hex string>          # [REQUIRED]
# PII_ENCRYPTION_KEY_V2=<64-char hex string>     # Set during key rotation only

# ─────────────────────────────────────────────────────────────────────────────
# HMAC blind-index key [REQUIRED]
# Used for searchable blind indexes (member names, push endpoints).
# Generate the same way as PII_ENCRYPTION_KEY.
# ─────────────────────────────────────────────────────────────────────────────
PII_BLIND_INDEX_KEY=<64-char hex string>

# ─────────────────────────────────────────────────────────────────────────────
# Web Push (VAPID) [REQUIRED for push notifications]
# Generate with: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:admin@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis — edge-compatible rate limiting (improvement #3)
# Create a free database at https://console.upstash.com
# Copy the REST API URL and token from the database detail page.
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io    # [REQUIRED in production]
UPSTASH_REDIS_REST_TOKEN=<token>                        # [REQUIRED in production]

# Set to "true" in .env.local to skip Redis entirely during local development.
# NEVER set this in production — it disables all rate limiting.
# UPSTASH_DISABLE_RATE_LIMIT=true

# ─────────────────────────────────────────────────────────────────────────────
# App URL — used by CSRF middleware (improvement #1) to validate Origin headers
# Set to your canonical deployment URL (no trailing slash).
# On Vercel this is automatically available; explicitly set it for other hosts.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app        # [REQUIRED in production]

# ─────────────────────────────────────────────────────────────────────────────
# CSRF bypass secret — for trusted server-to-server / webhook callers
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Callers include the header:  X-CSRF-Bypass: <this value>
# Leave unset if you have no server-to-server callers.
# ─────────────────────────────────────────────────────────────────────────────
# CSRF_BYPASS_SECRET=<random-secret>
